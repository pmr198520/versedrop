# Copy this file to .env and fill in your values.
# These are read at config time by app.config.ts and exposed via expo-constants.

# Backend API URL — used by src/lib/api.ts
# - Android emulator default: http://10.0.2.2:3001
# - iOS simulator:            http://localhost:3001
# - Physical device:          http://YOUR_LAN_IP:3001
# - Production:               https://api.yourdomain.com
EXPO_PUBLIC_API_URL=http://10.0.2.2:3001

# Google Maps API key — required for Android map rendering and optional on iOS.
# Get one at https://console.cloud.google.com/apis/credentials
# In CI / EAS builds, set this as an EAS secret instead of committing.
GOOGLE_MAPS_API_KEY=
