# Copy to api/.env and fill in for production.
# In dev (no DATABASE_URL set), the server runs in in-memory mode.

# Port
PORT=3001

# PostgreSQL connection string (Postgres 14+ with PostGIS extension).
# Leave blank to use in-memory store for local dev.
# Example:  postgresql://user:password@host:5432/versedrop
DATABASE_URL=

# Comma-separated list of allowed CORS origins. Use * for all (dev only).
# In production, set to your web/mobile domains:
#   CORS_ORIGINS=https://app.versedrop.com,https://versedrop.com
CORS_ORIGINS=*

# Public URL of the marketing site / where email-verification links land.
# Used in transactional emails. Defaults to https://versedrop.app if unset.
PUBLIC_APP_URL=https://versedrop.app

# ---------- Postmark (transactional email) ----------
# Get a Server Token from https://postmarkapp.com → Servers → API Tokens.
# Verify a sender domain before going to production (DKIM/SPF records).
# Leave blank in dev to log emails to console instead of sending.
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=noreply@versedrop.app
POSTMARK_REPLY_TO=support@versedrop.app
POSTMARK_MESSAGE_STREAM=outbound

# ---------- Expo Push (mobile notifications) ----------
# Optional Access Token for rate-limit headroom and enhanced security.
# Get one at https://expo.dev → Account Settings → Access Tokens.
# Push works without it for low volume, but is recommended for production.
EXPO_ACCESS_TOKEN=

# Optional: Sentry DSN for error reporting. Leave blank to disable.
# SENTRY_DSN=

# Optional: NODE_ENV — set to "production" in deployment
NODE_ENV=development
